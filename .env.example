# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
WEB_ORIGIN=http://localhost:5173

# ── Database (docker-compose db service) ─────────────────────────────────────
DATABASE_URL=postgres://librarychat:librarychat@localhost:5432/librarychat

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret

# ── AI providers ─────────────────────────────────────────────────────────────
# TEST_MODE=1 swaps all AI calls to offline fakes (no keys needed).
TEST_MODE=0
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# Provider-prefixed model strings — switching provider is an env change (docs/02).
CHAT_MODEL=anthropic:claude-haiku-4-5
EXTRACTION_MODEL=anthropic:claude-haiku-4-5
JUDGE_MODEL=anthropic:claude-sonnet-5
EMBEDDING_MODEL=voyage-context-4
EMBEDDING_DIM=1024
# 32k model window per group (verified against the live API) minus margin
EMBED_GROUP_MAX_TOKENS=28000

# ── Ingestion & retrieval tuning (see docs/01, docs/02) ──────────────────────
QUEUE_CONCURRENCY=2
CHUNK_TOKENS=400
CHUNK_OVERLAP_PCT=15
EXTRACTION_EXCERPT_TOKENS=30000
AGENT_MAX_TOOL_CALLS=4
RETRIEVAL_TOP_K=8
MAX_TOKENS_CHAT=2048
MAX_TOKENS_EXTRACTION=4096

# ── Input limits ─────────────────────────────────────────────────────────────
MAX_FILE_MB=25
MAX_FILES_PER_UPLOAD=10
MAX_PASTE_CHARS=500000
MAX_DOC_TOKENS=600000
MAX_CHAT_MESSAGE_CHARS=4000

# ── Rate limiting (per authenticated user) ───────────────────────────────────
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW=1 minute

# ── Seed script demo account (pnpm seed) ─────────────────────────────────────
DEMO_EMAIL=demo@library-chat.dev
DEMO_PASSWORD=demo-password

# ── Observability (optional — tracing activates purely via these) ────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=library-chat
